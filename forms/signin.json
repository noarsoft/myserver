{
    "type": "view",
    "style": {
        "padding": 20,
        "flex": 1,
        "justifyContent": "center",
        "alignItems": "center"
    },
    "controls": [
        {
            "type": "text",
            "value": "Sign In",
            "style": {
                "fontSize": 24,
                "fontWeight": "bold",
                "marginBottom": 20
            }
        },
        {
            "type": "textbox",
            "value": "",
            "datamap": "username",
            "placeholder": "Username",
            "style": {
                "borderColor": "#ccc",
                "borderWidth": 1,
                "borderRadius": 5,
                "padding": 10,
                "marginBottom": 15,
                "width": "80%"
            }
        },
        {
            "type": "textbox",
            "value": "",
            "datamap": "passx",
            "placeholder": "Password",
            "style": {
                "borderColor": "#ccc",
                "borderWidth": 1,
                "borderRadius": 5,
                "padding": 10,
                "marginBottom": 20,
                "width": "80%"
            },
            "is_password": true
        },
        {
            "type": "button",
            "value": "Sign In",
            "style": {
                "backgroundColor": "#007BFF",
                "padding": 15,
                "borderRadius": 5,
                "width": "80%",
                "alignItems": "center"
            },
            "textStyle": {
                "color": "#fff",
                "fontSize": 16,
                "fontWeight": "bold"
            },
            "onPress": "handleSignIn"
        }
    ]
}
