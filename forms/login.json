{
    "type": "view",
    "style": {
        "flexDirection": "column",
        "padding": 10
    },
    "controls": [
        {
            "type": "view",
            "style": {
                "flexDirection": "row",
                "alignItems": "center",
                "marginBottom": 10
            },
            "controls": [
                {
                    "type": "text",
                    "value": "Username:",
                    "style": { "width": 100, "fontSize": 16 }
                },
                {
                    "type": "textbox",
                    "datamap": "username",
                    "value": "",
                    "style": { "flex": 1 }
                }
            ]
        },
        {
            "type": "view",
            "style": {
                "flexDirection": "row",
                "alignItems": "center",
                "marginBottom": 10
            },
            "controls": [
                {
                    "type": "text",
                    "value": "Password:",
                    "style": { "width": 100, "fontSize": 16 }
                },
                {
                    "type": "textbox",
                    "datamap": "password",
                    "is_password": true,
                    "value": "",
                    "style": { "flex": 1 }
                }
            ]
        },
        {
            "type": "view",
            "style": {
                "flexDirection": "row",
                "alignItems": "center",
                "marginBottom": 20
            },
            "controls": [
                {
                    "type": "text",
                    "value": "Picture:",
                    "style": { "width": 100, "fontSize": 16 }
                },
                {
                    "type": "image",
                    "src": "https://raw.githubusercontent.com/noarsoft/myserver/refs/heads/master/forms/null.png",
                    "width": 100,
                    "height": 100
                }
            ]
        },
        {
            "type": "button",
            "value": "Login",
            "style": {
                "padding": 10,
                "backgroundColor": "#007BFF",
                "color": "#FFF",
                "alignItems": "center",
                "borderRadius": 5
            },
            "onPress": "handleLogin"
        },
        {
            "type": "view",
            "style": {
                "flexDirection": "row",
                "alignItems": "center",
                "justifyContent": "center",
                "marginTop": 20
            },
            "controls": [
                {
                    "type": "text",
                    "value": "Don't have an account?",
                    "style": { "fontSize": 16 }
                },
                {
                    "type": "button",
                    "value": "Sign Up",
                    "style": {
                        "marginLeft": 10,
                        "paddingVertical": 10,
                        "paddingHorizontal": 20,
                        "backgroundColor": "#28a745",
                        "color": "#FFF",
                        "borderRadius": 5
                    },
                    "onPress": "navigateToSignUp"
                }
            ]
        }
    ]
}
