{
    "type": "view",
    "controls": [
        {
            "type": "button",
            "value": "Submit",
            "style": { "padding": 10, "backgroundColor": "#007BFF", "borderRadius": 5 },
            "datamap": "submitButton",
            "onPress": "Submit button clicked"
        },
        {
            "type": "label",
            "text": "Dynamic Label",
            "style": { "fontSize": 18, "color": "green" },
            "containerStyle": { "backgroundColor": "#dff0d8", "padding": 10 },
            "datamap": "dynamicLabel",
            "onPress": "handleDynamicLabelClick"
        },
        {
            "type": "textbox",
            "value": "Enter your name",
            "style": { "padding": 10, "borderWidth": 1, "borderColor": "#ccc", "borderRadius": 5 },
            "datamap": "userNameInput"
        },
        {
            "type": "textboxtag",
            "data": [
                { "key": "1", "value": "React" },
                { "key": "2", "value": "JavaScript" },
                { "key": "3", "value": "TypeScript" }
            ],
            "placeholder": "Type a skill...",
            "datamap": "userSkills"
        },
        {
            "type": "toggle",
            "initialToggleState": true,
            "datamap": "userToggleSwitch"
        },
        {
            "type": "dropdown",
            "options": [
                { "label": "Option 1", "value": "1" },
                { "label": "Option 2", "value": "2" },
                { "label": "Option 3", "value": "3" }
            ],
            "datamap": "userDropdownSelection",
            "initialSelectedValue": "1"
        },
        {
            "type": "calendar",
            "day": 15,
            "month": 5,
            "year": 2023,
            "datamap": "userCalendarSelection"
        },
        {
            "type": "datepicker",
            "day": 10,
            "month": 4,
            "year": 2023,
            "highlightedDates": ["10-4-2023", "15-4-2023"],
            "datamap": "userDatePicker"
        },
        {
            "type": "optionbox",
            "options": [
                { "id": "1", "label": "Option A" },
                { "id": "2", "label": "Option B" }
            ],
            "datamap": "userOptionBox"
        },
        {
            "type": "timeinput",
            "value": "12:30",
            "datamap": "userTimeInput"
        },
        {
            "type": "table",
            "headers": [
                { "key": "name", "label": "Name", "type": "text" },
                { 
                    "key": "profilePic", 
                    "label": "Profile Picture", 
                    "type": "image", 
                    "style": { "justifyContent": "center" }, 
                    "imageStyle": { "width": 100, "height": 100 } 
                },
                { "key": "location", "label": "Location", "type": "text" }
            ],
            "data": [
                { "name": "Alicex", "profilePic": "https://raw.githubusercontent.com/noarsoft/myserver/refs/heads/master/forms/null.png", "location": "New York" },
                { "name": "Bobx", "profilePic": "https://raw.githubusercontent.com/noarsoft/myserver/refs/heads/master/forms/null.png", "location": "San Francisco" }
            ],
            "datamap": "userTable"
        },
        {
            "type": "vtable",
            "headers": [
                { "key": "name", "label": "Name", "type": "text","style": { "justifyContent": "left" } },
                { 
                    "key": "profilePic", 
                    "label": "Profile Picture", 
                    "type": "image", 
                    "style": { "justifyContent": "center" }, 
                    "imageStyle": { "width": 100, "height": 100 } 
                },
                { "key": "location", "label": "Location", "type": "text" }
            ],
            "data": [
                { "name": "Alicez", "profilePic": "https://raw.githubusercontent.com/noarsoft/myserver/refs/heads/master/forms/null.png", "location": "New York" },
                { "name": "Bobz", "profilePic": "https://raw.githubusercontent.com/noarsoft/myserver/refs/heads/master/forms/null.png", "location": "San Francisco" }
            ],
            "datamap": "userVtable"
        },
        {
            "type": "pagination",
            "page_no": 2,
            "page_total": 10,
            "datamap": "PaginationControl",
            "onNext": "handleNextPage",
            "onPrevious": "handlePreviousPage"
        },
        {
            "type": "imagelist",
            "imgs": [
                "https://raw.githubusercontent.com/noarsoft/myserver/refs/heads/master/forms/null.png",
                "https://raw.githubusercontent.com/noarsoft/myserver/refs/heads/master/forms/null.png"
            ],
            "datamap": "imageGallery"
        },
        {
                    "type": "image",
                    "src": "https://raw.githubusercontent.com/noarsoft/myserver/refs/heads/master/forms/null.png",
                    "width": 100,
                    "height": 100,
                    "datamap": "UserImageDisplay"
                },
        {
            "type": "textarea",
            "placeholder": "Enter your comments...",
            "datamap": "userComments"
        },
        {
            "type": "video",
            "source": "https://file-examples.com/storage/fe83e8a190674337794c387/2017/04/file_example_MP4_480_1_5MG.mp4",
            "style": { "borderRadius": 10 },
            "containerStyle": { "margin": 20 },
            "mapdata": "exampleVideo",
            "showControls": true,
            "loop": true
        },
        {
            "type": "music",
            "source": "https://samples-files.com/samples/audio/mp3/sample-file-4.mp3",
            "style": { "margin": 20 },
            "mapdata": "exampleMusic"
        },
        {
            "type": "qrcode",
            "value": "test",
            "size": 150,
            "backgroundColor": "#FFFFFF",
            "color": "#000000",
            "containerStyle": { "margin": 20 },
            "mapdata": "exampleQRCode"
        },
        {
            "type":"camera",
            "containerStyle": { "margin": 20 },
            "style": { "height": 400 }
        },
        {
            "type": "cameraqrcode",
            "containerStyle": { "margin": 20 },
            "style": { "height": 400 }
        }

    ]
}

